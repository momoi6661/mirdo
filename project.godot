[layer_names]

3d_physics/layer_1="world_character"
3d_physics/layer_2="cloth_soft_body"
3d_physics/layer_8="cloth_collision"

[navigation]

3d/default_cell_size=0.1
3d/default_cell_height=0.02

[physics]

common/physics_ticks_per_second=120
common/physics_jitter_fix=0.0
3d/physics_engine="Jolt Physics"
jolt_physics_3d/simulation/generate_all_kinematic_contacts=true
jolt_physics_3d/simulation/soft_body_point_radius=0.008
common/physics_interpolation=true

[rendering]

textures/default_filters/anisotropic_filtering_level=4
viewport/hdr_2d=true
anti_aliasing/quality/msaa_3d=3
textures/default_filters/texture_mipmap_bias=-1.0
anti_aliasing/quality/screen_space_aa=1
