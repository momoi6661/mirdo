[resource]
script = ExtResource("1_rule_set")
entries = Array[Resource]([SubResource("hunger_very_hungry"), SubResource("hunger_hungry"), SubResource("hunger_normal"), SubResource("thirst_very_thirsty"), SubResource("thirst_thirsty"), SubResource("thirst_normal"), SubResource("mood_good"), SubResource("mood_low"), SubResource("mood_neutral"), SubResource("favor_close"), SubResource("favor_distant"), SubResource("favor_neutral"), SubResource("status_poor"), SubResource("status_happy_close")])
