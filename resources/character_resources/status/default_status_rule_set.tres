[gd_resource type="Resource" script_class="CharacterStatusRuleSetResource" format=3]

[ext_resource type="Script" path="res://scripts/character_resources/resources/character_status_rule_set_resource.gd" id="1_rule_set"]
[ext_resource type="Script" path="res://scripts/character_resources/resources/character_status_rule_resource.gd" id="2_rule"]
[ext_resource type="Script" path="res://scripts/character_resources/resources/character_status_value_state_resource.gd" id="3_value_state"]

[sub_resource type="Resource" id="hunger_very_hungry"]
script = ExtResource("3_value_state")
id = &"hunger_very_hungry"
