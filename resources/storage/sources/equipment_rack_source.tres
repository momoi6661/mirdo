[gd_resource type="Resource" script_class="ShelterStorageSourceResource" format=3]

[ext_resource type="Script" path="res://scripts/Inventory/shelter_storage_source_resource.gd" id="1_source_script"]
[ext_resource type="Resource" path="res://resources/storage/equipment_rack_storage.tres" id="2_storage"]

[resource]
script = ExtResource("1_source_script")
source_id = &"equipment_rack"
display_name = "武器/装备柜"
source_kind = "equipment"
storage = ExtResource("2_storage")
include_in_outing_pool = true
notes = "24格武器/装备柜；武器不堆叠，普通工具和特殊装备按物品上限堆叠；外出准备界面只读取库存，不允许反向存入。"
