[gd_resource type="Resource" script_class="OutingUnlockLinkResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_unlock_link_resource.gd" id="1_link"]
[resource]
script = ExtResource("1_link")
from_location_id = &"hardware_store"
to_location_id = &"police_checkpoint"
unlock_key = &"hardware_store_roadblock_note"
required_success_count = 1
discovery_text = "从五金店街口标记发现临时警戒点。"
ai_discovery_rule = "当 hardware_store 探索成功时，AI 可以用环境线索把视野沿道路向外推进到 police_checkpoint。这是路线发现，不是地点直连显示，也不是新庇护所。"
