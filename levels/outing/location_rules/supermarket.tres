[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"supermarket"
display_name = "小型超市"
description = "社区超市入口被购物车堵住。食物、水和日用品概率高，但内部遮挡多。"
map_position = Vector2(180, 300)
route_hint = "沿住宅区北侧支路进入，货架遮挡多，地图路线收益明显。"
icon_text = "◉"
threat_level = 3
travel_minutes = 200
discoverable = false
start_unlocked = true
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("食物", "水", "日用品", "基础补给", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "近战武器", "地图册")
detail_notes = PackedStringArray("货架遮挡视线", "基础物资收益高", "购物车区域会制造噪声")
ai_exploration_rule = "丧尸末世探索：小型超市货架遮挡多，冷柜腐败、购物车路障和仓储间都可能藏丧尸。AI 应描写压低声音穿过货架、判断能否进入仓储间、被尸群堵住通道时放弃部分物资。收益偏食物、水、日用品；手电减少遗漏，近战武器处理近距离威胁。不可向外发现新区域，不可变成庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
