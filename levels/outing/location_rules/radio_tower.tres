recommended_auxiliary_tools = PackedStringArray("手电", "近战武器", "医疗包")
detail_notes = PackedStringArray("北侧外缘高点", "可获得远距地图情报", "机房狭窄且噪声明显")
ai_exploration_rule = "AI 应生成旧广播塔、机房、电缆井和高处眺望的探索叙事。成功后可根据解锁资源向更远地区提供线索；不能生成庇护所。"

