[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"radio_tower"
display_name = "旧广播塔"
description = "城市北侧的旧广播塔，塔下机房可能有通讯零件和远处地标线索。"
map_position = Vector2(1540, -1030)
route_hint = "沿北侧外环高点进入，适合获取更远的地图情报。"
icon_text = "⌁"
threat_level = 4
travel_minutes = 280
discoverable = true
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("通讯零件", "电池", "线缆", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "近战武器", "医疗包")
detail_notes = PackedStringArray("北侧外缘高点", "可获得远距地图情报", "机房狭窄且噪声明显")
ai_exploration_rule = "丧尸末世探索：旧广播塔高处可观察远方，但机房、电缆井和塔梯都有跌落与丧尸围堵风险。AI 应描写爬升前侦查、机房搜索、电池/线缆拆取和高处看到的尸群流向。成功后可根据解锁资源提供更远地区线索；不能生成庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"

