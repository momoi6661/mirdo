detail_notes = PackedStringArray("东南外缘补给点", "收益偏食物和种子", "空旷但撤退路线长")
ai_exploration_rule = "丧尸末世探索：郊边农贸棚空旷但撤退距离长，塑料箱、冷藏摊、装卸棚和腐烂食物会吸引游荡尸群。AI 要强调搬运限制和远路返程压力。收益偏食物、种子、工具；可能因尸群穿过空地而只带走少量物资；不能生成新庇护所。"
