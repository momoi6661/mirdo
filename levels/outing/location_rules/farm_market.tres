[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"farm_market"
display_name = "郊边农贸棚"
description = "东南外缘的农贸棚和装卸区，可能有干粮、种子和简易工具。"
map_position = Vector2(1500, 760)
route_hint = "沿东南外环道路抵达，空旷安全感高但撤退距离长。"
icon_text = "◌"
threat_level = 2
travel_minutes = 260
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("食物", "种子", "工具", "基础补给", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("地图册", "近战武器", "手电")
detail_notes = PackedStringArray("东南外缘补给点", "收益偏食物和种子", "空旷但撤退路线长")
ai_exploration_rule = "丧尸末世探索：郊边农贸棚空旷但撤退距离长，塑料箱、冷藏摊、装卸棚和腐烂食物会吸引游荡尸群。AI 要强调搬运限制和远路返程压力。收益偏食物、种子、工具；可能因尸群穿过空地而只带走少量物资；不能生成新庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
