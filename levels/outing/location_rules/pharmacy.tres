[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"pharmacy"
display_name = "转角药房"
description = "住宅区外侧的转角药房，柜台后方可能还有药品和消毒物。"
map_position = Vector2(-620, 760)
route_hint = "沿住宅外侧转角路进入，柜台后方可能上锁。"
icon_text = "+"
threat_level = 3
travel_minutes = 210
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("药品", "绷带", "消毒物", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("撬棍", "手电", "消毒药")
detail_notes = PackedStringArray("住宅区外缘医疗点", "柜台后方可能被锁", "适合补医疗物资")
ai_exploration_rule = "丧尸末世探索：转角药房玻璃破碎、柜台后方上锁，药柜和小仓库可能残留感染者。AI 应描写粉尘、药瓶碎片、过期药筛选和被丧尸堵门的风险。收益偏药品、绷带、消毒物；可以因尸群靠近而只拿到少量物资或空手撤退。禁止庇护所相关展开。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
