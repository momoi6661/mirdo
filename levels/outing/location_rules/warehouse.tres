[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"warehouse"
display_name = "河岸仓库"
description = "河岸边的小型仓库，卷门锁死，里面可能有成箱物资和大型零件。"
map_position = Vector2(-1780, -910)
route_hint = "沿河岸货运路进入，卷门锁死，搬运收益高但撤退慢。"
icon_text = "▣"
threat_level = 4
travel_minutes = 260
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("大型零件", "工具", "食物箱", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("撬棍", "近战武器", "地图册")
detail_notes = PackedStringArray("卷门锁死", "大件物资多但搬运困难", "河岸环境会放大噪声")
ai_exploration_rule = "丧尸末世探索：河岸仓库卷门锁死、货架高、木箱多，河岸回声会让丧尸从装卸口靠近。AI 应描写撬卷门、搬运取舍、货架间遭遇和撤退慢的问题。撬棍用于开启卷门，地图册提高路线判断，武器降低遭遇风险。收益偏大型零件、工具、食物箱；不能生成庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
