[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"school"
display_name = "废弃小学"
description = "学校操场空旷，教学楼里可能有医药箱、文具、电池和临时避难遗留物。"
map_position = Vector2(-720, 1020)
route_hint = "沿南侧学校路进入，房间多但路线清晰，适合搜电池和药箱。"
icon_text = "✎"
threat_level = 2
travel_minutes = 220
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("电池", "药品", "杂物", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "消毒药", "医疗包")
detail_notes = PackedStringArray("房间多，搜索时间长", "粉尘较重", "收益偏杂项和电池")
ai_exploration_rule = "丧尸末世探索：废弃小学有操场、教室、医务室和储物柜，空旷走廊会放大脚步声。AI 应描写教室搜索、医务室风险、孩童物品带来的压抑感和尸群从校门聚集的压力。绷带和消毒药降低受伤后果，手电减少遗漏。可发现临时避难痕迹但不能成为玩家新庇护所。收益偏电池、药品、杂物。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
