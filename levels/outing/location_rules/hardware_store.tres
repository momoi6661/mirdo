[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"hardware_store"
display_name = "五金工具店"
description = "街边五金店卷帘门半塌，里面可能有紧固件、胶带、电线和手动工具。"
map_position = Vector2(1080, -360)
route_hint = "沿东侧商铺街推进，卷帘门和库房会消耗工具耐久。"
icon_text = "⚒"
threat_level = 2
travel_minutes = 170
discoverable = true
start_unlocked = false
neighbor_location_ids = PackedStringArray("police_checkpoint")
loot_bias_tags = PackedStringArray("工具", "电线", "胶带")
recommended_auxiliary_tools = PackedStringArray("撬棍", "手电", "折叠背包")
detail_notes = PackedStringArray("卷帘门需要撬动", "小零件很多，搜索收益稳定", "可继续向城市外缘发现警戒点线索")
ai_exploration_rule = "AI 应生成五金店内部货架、柜台、卷帘门和散落零件。携带撬棍可进入锁住货柜；折叠背包提高携回叙事。成功时沿外缘道路发现 police_checkpoint。禁止庇护所相关内容。"
