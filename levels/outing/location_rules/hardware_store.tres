[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"hardware_store"
display_name = "五金工具店"
description = "街边五金店卷帘门半塌，里面可能有紧固件、胶带、电线和手动工具。"
map_position = Vector2(1080, -360)
route_hint = "沿东侧商铺街推进，卷帘门和库房会消耗工具耐久。"
icon_text = "⚒"
threat_level = 2
travel_minutes = 170
discoverable = true
start_unlocked = false
neighbor_location_ids = PackedStringArray("police_checkpoint")
loot_bias_tags = PackedStringArray("工具", "电线", "胶带", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("撬棍", "手电", "地图册")
detail_notes = PackedStringArray("卷帘门需要撬动", "小零件很多，搜索收益稳定", "可继续向城市外缘发现警戒点线索")
ai_exploration_rule = "丧尸末世探索：五金工具店卷帘门半塌、货架倒伏、库房阴暗，敲击金属会吸引丧尸。AI 应描写柜台、锁住货柜、散落零件和临时撤退路线；撬棍可进入锁柜，地图册提高路线判断。成功时沿外缘道路发现 police_checkpoint。禁止庇护所相关内容。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
