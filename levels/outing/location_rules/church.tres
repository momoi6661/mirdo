[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"church"
display_name = "老教堂"
description = "西南方向的老教堂，避难痕迹很多，但现在只适合搜集蜡烛、布料和记录。"
map_position = Vector2(-1420, 820)
route_hint = "沿西南旧街区进入，只作为搜集点，不作为新据点。"
icon_text = "✣"
threat_level = 3
travel_minutes = 300
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("蜡烛", "布料", "记录", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "消毒药", "医疗包")
detail_notes = PackedStringArray("西南外缘建筑", "只记录旧避难痕迹，不开放为据点", "可能找到旧记录")
ai_exploration_rule = "丧尸末世探索：老教堂有避难痕迹、翻倒长椅、告解室和钟楼回声，尸群可能被钟声或脚步吸引。AI 可以描写旧记录、蜡烛、布料和信徒遗留物，但必须明确这里只是搜集点，不能成为玩家庇护所。探索可能因大厅尸群而提前撤退。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
