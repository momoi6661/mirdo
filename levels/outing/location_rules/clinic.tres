[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"clinic"
display_name = "街区诊所"
description = "小型诊所入口被杂物挡住。药柜可能尚未被完全搬空。"
map_position = Vector2(640, -450)
route_hint = "沿东北街区小路进入，入口狭窄，适合携带撬棍和消毒药。"
icon_text = "+"
threat_level = 3
travel_minutes = 210
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("药品", "绷带", "消毒物", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("撬棍", "手电", "消毒药")
detail_notes = PackedStringArray("外缘医疗方向", "入口狭窄", "医疗收益较高")
ai_exploration_rule = "丧尸末世探索：街区诊所入口狭窄，药柜、治疗室、候诊区和后门都可能藏着感染者。AI 需要描写粉尘/血迹/玻璃/感染风险；消毒药和医疗物资能降低受伤后果，撬棍可处理阻塞入口，手电减少遗漏。收益偏医疗物资；不向外发现新区域，不允许生成可住院或庇护设定。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
