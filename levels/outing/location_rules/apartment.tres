[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"apartment"
display_name = "破旧公寓楼"
description = "住宅区外侧的多层公寓，房间密集，生活物资多但搜索时间很长。"
map_position = Vector2(420, 1020)
route_hint = "沿南侧公寓支路逐层搜索，房间密集且噪声容易累积。"
icon_text = "▦"
threat_level = 3
travel_minutes = 290
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("食物", "水", "布料", "基础补给", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "近战武器", "地图册")
detail_notes = PackedStringArray("房间密集", "搜索时间长", "收益偏生活物资")
ai_exploration_rule = "丧尸末世探索：破旧公寓楼走廊狭窄、门后可能有被困丧尸，楼梯间回声会放大噪音。AI 需要描写逐层听声、撬门/不开门的取舍、厨房与储物间搜索、可能被尸群逼退。收益偏食物、水、布料；可以少量受伤或空手返回；不能生成可入住据点。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
