[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"water_plant"
display_name = "小型净水站"
description = "河岸更深处的小型净水站，设备间可能有滤芯、管线和水处理用品。"
map_position = Vector2(-1870, -120)
route_hint = "沿河岸深处设施路进入，水处理收益高但返程最慢。"
icon_text = "≈"
threat_level = 4
travel_minutes = 330
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("滤芯", "管线", "净水剂", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("撬棍", "手电", "消毒药")
detail_notes = PackedStringArray("河岸深处设施", "路程远且撤退困难", "水处理收益高")
ai_exploration_rule = "丧尸末世探索：小型净水站位于河岸深处，设备间潮湿、管线复杂、回程最慢。AI 应描写水泵房、滤芯、管线、净水剂和潮湿环境导致的滑倒/感染风险。收益偏滤芯、管线、净水剂；高威胁下可以受伤或只拿到少量物资。不能生成新庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
