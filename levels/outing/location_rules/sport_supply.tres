[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"sport_supply"
display_name = "德州运动用品店"
description = "街角的旧运动用品店，可能残留护具、维修工具、弩箭或可改装武器零件。"
map_position = Vector2(260, -120)
route_hint = "沿中心商业街东段进入，成功后可外推车库、诊所、五金店线索。"
icon_text = "⚒"
threat_level = 3
travel_minutes = 160
discoverable = true
start_unlocked = true
neighbor_location_ids = PackedStringArray("garage", "clinic", "hardware_store")
loot_bias_tags = PackedStringArray("工具", "武器零件", "罐头")
recommended_auxiliary_tools = PackedStringArray("撬棍", "近战武器", "地图册")
detail_notes = PackedStringArray("入口噪声风险中等", "撬棍可提高库房收益", "可能发现更外缘的车库、诊所或五金店路线")
ai_exploration_rule = "AI 探索叙事应围绕运动用品店、破损橱窗、货架、后仓和武器/工具零件展开。携带撬棍时允许描写打开后仓并提高工具类收益；携带近战武器时降低遭遇损伤描写。禁止生成新庇护所。成功时沿主路向外发现 garage、clinic 或 hardware_store 的路线线索。"
