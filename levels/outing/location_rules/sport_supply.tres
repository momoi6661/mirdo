[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"sport_supply"
display_name = "德州运动用品店"
description = "街角的旧运动用品店，可能残留护具、维修工具、可改装武器零件，也可能在收银台和员工休息区找到水、能量棒或罐头。"
map_position = Vector2(260, -120)
route_hint = "沿中心商业街东段进入，成功后可外推车库、诊所、五金店线索。"
icon_text = "⚒"
threat_level = 3
travel_minutes = 160
discoverable = true
start_unlocked = true
neighbor_location_ids = PackedStringArray("garage", "clinic", "hardware_store")
loot_bias_tags = PackedStringArray("工具", "武器零件", "基础补给", "罐头", "水", "食物", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("撬棍", "近战武器", "地图册")
detail_notes = PackedStringArray("入口噪声风险中等", "撬棍可提高库房收益", "可能发现更外缘的车库、诊所或五金店路线")
ai_exploration_rule = "丧尸末世探索：运动用品店有破损橱窗、货架、后仓、护具、可改造成武器的零件，也有员工休息区的水、能量棒和罐头。AI 应描写进店前观察尸群、翻找货架、打开后仓和撤退压力。携带撬棍允许打开后仓并提高工具/武器零件收益；携带近战武器降低遭遇损伤。禁止生成新庇护所。成功时沿主路向外发现 garage、clinic 或 hardware_store 路线线索。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
