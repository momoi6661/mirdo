[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"taxi_depot"
display_name = "废弃出租车站"
description = "被遗弃的出租车调度点。车辆残骸里可能有燃料、地图册和车载工具。"
map_position = Vector2(-280, -80)
route_hint = "沿西侧主路抵达，车辆残骸适合快速搜刮并发现燃料线索。"
icon_text = "◆"
threat_level = 2
travel_minutes = 110
discoverable = true
start_unlocked = true
neighbor_location_ids = PackedStringArray("garage", "gas_station")
loot_bias_tags = PackedStringArray("燃料", "零件", "地图线索", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "近战武器")
detail_notes = PackedStringArray("空旷区域视野好", "车辆残骸可快速搜刮", "可能沿西侧道路发现更远地点")
ai_exploration_rule = "丧尸末世探索：废弃出租车站开阔但车辆残骸多，车门警报和调度室噪音会吸引游荡者。AI 应描写快速搜刮油箱、工具箱、路线图和车站办公室。风险来自空旷地带被包围；成功时沿西侧道路向外发现 garage 或 gas_station 路线。禁止生成可定居地点。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
