[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"garage"
display_name = "高架桥维修车库"
description = "高架桥下的维修车库，被路障和废车包围。可能产出高价值工具，但需要更强辅助装备。"
map_position = Vector2(820, -130)
route_hint = "沿东侧高架维修线进入，撤离路线短但遭遇强度高。"
icon_text = "⚙"
threat_level = 4
travel_minutes = 240
discoverable = true
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("高级零件", "燃料", "工具", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手枪", "撬棍", "医疗包")
detail_notes = PackedStringArray("外缘工业方向", "需要先发现路线", "建议携带防身装备")
ai_exploration_rule = "丧尸末世探索：高架桥维修车库阴影重、废车密集、工具柜上锁，噪音会在桥下聚集尸群。AI 应描写高威胁遭遇、废车掩体、撬柜/撤退取舍；携带武器降低受伤，撬棍提高工具收益，医疗包缓解事故。只能产生资源和路线线索，不能成为庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
