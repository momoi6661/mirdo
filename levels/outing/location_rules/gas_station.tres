[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"gas_station"
display_name = "锈蚀加油站"
description = "主干道旁的旧加油站，地下油罐和便利店后仓都值得检查。"
map_position = Vector2(-980, -420)
route_hint = "沿西北主干道抵达，油罐区禁止明火，可继续外推河岸路线。"
icon_text = "♦"
threat_level = 3
travel_minutes = 150
discoverable = true
start_unlocked = false
neighbor_location_ids = PackedStringArray("warehouse")
loot_bias_tags = PackedStringArray("燃料", "电池", "零食")
recommended_auxiliary_tools = PackedStringArray("手电", "近战武器", "地图册")
detail_notes = PackedStringArray("油气味重，禁止明火", "便利店货架可能有残余补给", "可继续向河岸外缘发现仓库路线")
ai_exploration_rule = "丧尸末世探索：锈蚀加油站包含便利店货架、地下油罐、车辆残骸和易燃泄漏区。AI 应描写燃料气味、玻璃碎裂、车辆警报和丧尸被噪声吸引。燃料收益高但风险高；手电可检查后仓，武器降低遭遇损伤。成功时沿西北道路向外发现 warehouse 线索。禁止生成庇护所。"
