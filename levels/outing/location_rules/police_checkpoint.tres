[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"police_checkpoint"
display_name = "临时警戒点"
description = "街口残留的临时警戒点，有废弃警车、路障和临检帐篷。"
map_position = Vector2(1760, -520)
route_hint = "沿城市外环抵达，高威胁拦截点，建议装备齐全后再行动。"
icon_text = "⚠"
threat_level = 5
travel_minutes = 230
discoverable = false
start_unlocked = false
neighbor_location_ids = PackedStringArray()
loot_bias_tags = PackedStringArray("弹药", "防具", "通讯零件", "基础补给", "食物", "水", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手枪", "医疗包", "撬棍")
detail_notes = PackedStringArray("最高威胁区域", "可能有防具或弹药", "建议准备充分后再去")
ai_exploration_rule = "丧尸末世探索：临时警戒点是高威胁区域，废弃警车、路障、帐篷和弹药箱周围有密集丧尸。AI 应生成压迫感强的接近、观察、短促搜索和撤退。携带手枪/近战武器/医疗包会显著改善结果；收益偏弹药、防具、通讯零件。可以受伤或无收益撤退；绝不能占领警戒点作为新庇护所。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
