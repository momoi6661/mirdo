[gd_resource type="Resource" script_class="OutingLocationRuleResource" format=3]
[ext_resource type="Script" path="res://levels/outing/resources/outing_location_rule_resource.gd" id="1_rule"]
[resource]
script = ExtResource("1_rule")
location_id = &"residential"
display_name = "格林黑文住宅区"
description = "低层住宅区。风险不高，但房间多、搜索时间长，适合补充基础生活物资。"
map_position = Vector2(-120, 330)
route_hint = "沿南向住宅支路搜索，适合低风险补给但耗时偏长。"
icon_text = "◼"
threat_level = 2
travel_minutes = 190
discoverable = true
start_unlocked = true
neighbor_location_ids = PackedStringArray("school")
loot_bias_tags = PackedStringArray("食物", "水", "布料", "基础补给", "医疗包", "武器")
recommended_auxiliary_tools = PackedStringArray("手电", "医疗包", "小刀")
detail_notes = PackedStringArray("室内搜索较慢", "低概率遭遇游荡者", "适合缺水缺粮时前往")
ai_exploration_rule = "丧尸末世探索：格林黑文住宅区适合低风险补给，但逐户搜索耗时，厨房、储物柜、卧室门后可能有游荡者。AI 应描写敲门听声、绕开拥堵房屋、生活物资搜集和返程。收益偏食物、水、布料；手电减少遗漏，医疗包处理轻伤。成功时可沿住宅区外缘发现 school；不允许生成庇护所替代方案。 必须把本地点写成一次有开端、探索、意外、取舍和撤离的连续故事；loot只能来自可用物资；由AI按探索过程判断收益多少；允许空手、受伤、携带物消耗或武器/工具损坏；绝不生成新庇护所。 全局收益规则：所有外出地点都有机会找到基础生存物资，包括食物、水、急救箱/绷带/药品；也可能在尸体、车辆、柜台或工具角落找到简易武器。AI 应按地点类型、搜索深度、携带工具、威胁等级和撤离是否顺利来判断loot数量与种类，不要固定少量奖励；成功搜索可多拿，受伤或被尸群逼退则少拿或损坏/消耗携带物。"
